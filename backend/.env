# Konfigurasi Backend Wisata Indonesia
PORT=4000
MONGODB_URI=mongodb://localhost:27017/wisata_indonesia
CLIENT_ORIGIN=http://localhost:3000

# --- AI (opsional) ---
# Isi salah satu untuk mengaktifkan jawaban AI berbasis LLM.
# Kosongkan untuk memakai asisten offline bawaan.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Ollama (penyedia AI utama) ---
OLLAMA_URL=https://ollama.if.unismuh.ac.id/api/generate
OLLAMA_MODEL=gemma4
# OLLAMA_DISABLED=1  # set 1 untuk mematikan Ollama & pakai fallback
